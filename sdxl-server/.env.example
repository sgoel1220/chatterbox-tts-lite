# ── CivitAI ──────────────────────────────────────────────────────────────────
# Get your token at: https://civitai.com/user/account (API Keys section)
CIVITAI_TOKEN=your_civitai_token_here

# CivitAI *version* ID for the base checkpoint.
# Find it: open the model page on CivitAI → click Download → copy the number
# from the URL: civitai.com/api/download/models/<VERSION_ID>
# Juggernaut XL Ragnarok: https://civitai.com/models/133005
BASE_CIVITAI_ID=456194

# Comma-separated  name:version_id  for LoRAs.
# Each becomes /loras/<name>.safetensors
LORA_CIVITAI_IDS=ClassipeintXL_v2.1:176425,Eldritch_Impressionism:12345

# ── HuggingFace (optional) ────────────────────────────────────────────────────
# Only needed for private/gated models. SDXL 1.0 is public.
HF_TOKEN=
