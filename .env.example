# Shared local Compose settings. Copy to .env and fill in real secrets.

METADATA_POSTGRES_PASSWORD=changeme
METADATA_API_KEY=change_me_to_a_long_random_secret
STORY_ENGINE_API_KEY=change_me_to_a_long_random_secret

CREEPY_POSTGRES_PASSWORD=dev_password
HATCHET_COOKIE_SECRETS=devtokensecret16 devtokensecret32

# Creepy Brain LLM settings.
# Anthropic:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-6
#
# OpenRouter:
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-opus-4-6

# Host ports.
TTS_LISTEN_PORT=8005
METADATA_LISTEN_PORT=8080
STORY_ENGINE_LISTEN_PORT=8090
CREEPY_BRAIN_LISTEN_PORT=8006
CREEPY_POSTGRES_LISTEN_PORT=5433
HATCHET_DASHBOARD_PORT=8888
HATCHET_GRPC_PORT=7070
